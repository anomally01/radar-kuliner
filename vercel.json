{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.2"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "public"
            }
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "Radar Kuliner",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://radar-kuliner.vercel.app",
        "APP_KEY": "@app_key",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp/views",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "SESSION_SECURE_COOKIE": "true",
        "CACHE_STORE": "array",
        "QUEUE_CONNECTION": "sync",
        "FILESYSTEM_DISK": "s3",
        "DB_CONNECTION": "@db_connection",
        "DB_HOST": "@db_host",
        "DB_PORT": "@db_port",
        "DB_DATABASE": "@db_database",
        "DB_USERNAME": "@db_username",
        "DB_PASSWORD": "@db_password",
        "AWS_ACCESS_KEY_ID": "@supabase_storage_key",
        "AWS_SECRET_ACCESS_KEY": "@supabase_storage_secret",
        "AWS_DEFAULT_REGION": "@supabase_storage_region",
        "AWS_BUCKET": "@supabase_storage_bucket",
        "AWS_ENDPOINT": "@supabase_storage_endpoint",
        "AWS_USE_PATH_STYLE_ENDPOINT": "true",
        "SUPABASE_STORAGE_URL": "@supabase_public_storage_url"
    }
}
