{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.2",
            "config": {
                "includeFiles": [
                    "app/**",
                    "bootstrap/**",
                    "config/**",
                    "database/**",
                    "public/**",
                    "resources/**",
                    "routes/**",
                    "storage/**",
                    "vendor/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(favicon\\.ico|robots\\.txt)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "Radar Kuliner",
        "APP_ENV": "production",
        "APP_KEY": "base64:IPFSemhnSPmTlNlSQ51ZT7IOxj6Dsl5t54J7hlYfumo=",
        "APP_DEBUG": "false",
        "APP_URL": "https://radar-kuliner-three.vercel.app",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp/views",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "SESSION_SECURE_COOKIE": "true",
        "CACHE_STORE": "array",
        "QUEUE_CONNECTION": "sync",
        "FILESYSTEM_DISK": "local",
        "AWS_USE_PATH_STYLE_ENDPOINT": "true"
    }
}
